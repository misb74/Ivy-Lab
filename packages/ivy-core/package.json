{
  "name": "@ivy/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "import": "./dist/contracts/index.js"
    },
    "./orchestrator": {
      "types": "./dist/orchestrator/index.d.ts",
      "import": "./dist/orchestrator/index.js"
    },
    "./scanner": {
      "types": "./dist/scanner/index.d.ts",
      "import": "./dist/scanner/index.js"
    },
    "./llm": {
      "types": "./dist/llm/index.d.ts",
      "import": "./dist/llm/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "eval": "tsc -p tsconfig.test.json --noEmit && tsx test/golden/harness.ts",
    "eval-adversarial": "tsc -p tsconfig.test.json --noEmit && tsx test/adversarial/harness.ts"
  },
  "dependencies": {
    "zod": "3.24.4"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
