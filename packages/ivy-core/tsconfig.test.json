{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist-typecheck",
    "noEmit": true,
    "types": ["node", "vitest/globals"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "vitest.config.ts"],
  "exclude": [
    "dist",
    "dist-typecheck",
    "**/*section-b*",
    "**/*session*",
    "**/*message*",
    "**/*handoff*",
    "**/*mutation*",
    "**/*user-preferences*",
    "**/*artifact-cell*"
  ]
}
