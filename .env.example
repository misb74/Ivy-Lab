# ─── Required ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Data Connectors ────────────────────────────────────────────────
LIGHTCAST_CLIENT_ID=
LIGHTCAST_CLIENT_SECRET=
LIGHTCAST_SCOPE=classification_api
ONET_API_KEY=
BLS_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
FRED_API_KEY=

# ─── Supabase (AI Impact Atlas) ───────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Supabase (agent-ats-scanner — dedicated project) ─────────────
# Optional. If unset, agent-ats-scanner falls back to the main SUPABASE_* vars above.
ATS_SUPABASE_URL=
ATS_SUPABASE_SERVICE_ROLE_KEY=

# ─── Gateway ────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173

# ─── Sandbox (agent-codeops) ────────────────────────────────────────
SANDBOX_IMAGE=node:20-slim
SANDBOX_MEMORY_LIMIT=256m
SANDBOX_CPU_LIMIT=1
SANDBOX_TIMEOUT=30000

# ─── Cache ──────────────────────────────────────────────────────────
CACHE_TTL=3600
CACHE_DIR=.cache
VECTOR_STORE_PATH=data/memory
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=pretty

# ─── Talent Sourcing (Apollo + People Data Labs) ────────────────────
APOLLO_API_KEY=
PDL_API_KEY=

# ─── Research ───────────────────────────────────────────────────────
TAVILY_API_KEY=
EXA_API_KEY=

# ─── Voice ──────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─── Gemini (optional fallback) ─────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ─── Email (agent-email / agent-notification) ───────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# ─── Google OAuth / Drive ──────────────────────────────────────────
GOOGLE_OAUTH_CREDENTIALS=
GOOGLE_DRIVE_OAUTH_CREDENTIALS=
VITE_GOOGLE_DRIVE_API_KEY=
VITE_GOOGLE_DRIVE_CLIENT_ID=

# ─── Integrations (optional) ─────────────────────────────────────
NGROK_AUTHTOKEN=
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=

# ─── OCR (optional) ─────────────────────────────────────────────────
NANONETS_API_KEY=
NANONETS_MODEL_ID=
