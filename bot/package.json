{
  "name": "@ivy/bot",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node --env-file-if-exists=../.env --env-file-if-exists=.env --import tsx src/index.ts",
    "dev": "node --env-file-if-exists=../.env --env-file-if-exists=.env --import tsx --watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.138",
    "grammy": "^1.42.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
